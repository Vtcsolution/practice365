# ===== Practice365 Production Environment =====

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/practice365?retryWrites=true&w=majority

# JWT
JWT_SECRET=<generate-a-strong-64-char-random-string>
JWT_EXPIRE=7d

# Server
PORT=5000
NODE_ENV=production

# App URL (used for e-signature links, portal links)
APP_URL=https://yourdomain.com

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (optional — falls back to console logging if not set)
# Uncomment and configure when ready:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxx
# SMTP_FROM=noreply@yourdomain.com
